# Copy to .env and fill in. .env is gitignored — never commit real keys.
# docker compose reads .env automatically; for `mvn spring-boot:run` do:
#   set -a; . ./.env; set +a

# --- Database (local dev defaults match docker-compose) ---
DB_URL=jdbc:postgresql://localhost:5544/companieswatch
DB_USER=companieswatch
DB_PASSWORD=companieswatch

# --- Companies House Public Data (REST) API key ---
# From https://developer.company-information.service.gov.uk/ — used for backfill on add.
CH_REST_API_KEY=

# --- Companies House Streaming API key (separate registration / app) ---
# Leave blank to run without the live stream; the worker auto-skips when empty.
CH_STREAM_API_KEY=
# Streams to consume (max 2). Default catches the top lender signals: company profile
# changes (status/address) + charges. Drop to "companies" for a single connection.
CH_STREAM_NAMES=companies,charges

# --- Email alerts (optional; logging notifier is used until enabled) ---
# Flip ENABLED=true and fill MAIL_* to send real email. Provider-agnostic SMTP — works with
# AWS SES, Resend, Postmark, Gmail, etc. (use the provider's SMTP host/port/credentials).
ALERTS_EMAIL_ENABLED=false
ALERTS_EMAIL_FROM=alerts@britintel.app
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# --- Clerk auth (dashboard.clerk.com → API keys) ---
# Publishable key + frontend URL are public (served to the SPA); secret key is server-side only.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=https://<your-instance>.clerk.accounts.dev
