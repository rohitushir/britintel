# Copy to .env and fill in. .env is gitignored — never commit real keys.
# docker compose reads .env automatically; for `mvn spring-boot:run` do:
#   set -a; . ./.env; set +a

# --- Database (local dev defaults match docker-compose) ---
DB_URL=jdbc:postgresql://localhost:5544/companieswatch
DB_USER=companieswatch
DB_PASSWORD=companieswatch

# --- Companies House Public Data (REST) API key ---
# From https://developer.company-information.service.gov.uk/ — used for backfill on add.
CH_REST_API_KEY=

# --- Companies House Streaming API key (separate registration / app) ---
# Leave blank to run without the live stream; the worker auto-skips when empty.
CH_STREAM_API_KEY=
# Streams to consume (max 2). v1 default: companies. Add ",charges" to also catch charges.
CH_STREAM_NAMES=companies

# --- Email alerts (optional; logging notifier is used until enabled) ---
ALERTS_EMAIL_ENABLED=false
ALERTS_EMAIL_FROM=alerts@companieswatch.app
# When ALERTS_EMAIL_ENABLED=true, also set spring.mail.* (see application.yml).
